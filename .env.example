# Copy this file to .env and fill in HA_TOKEN. The .env file is gitignored.

# Home Assistant base URL (no trailing slash).
HA_BASE_URL=http://192.168.1.217:8123

# Long-lived access token: HA profile -> Security -> Long-lived access tokens.
HA_TOKEN=paste-your-long-lived-token-here

# The media_player entity for this room's player.
HA_ENTITY_ID=media_player.starlight_hifi

# Port Flask listens on. If you change this, update the URL in config/xinitrc too.
DASHBOARD_PORT=8080

# How often to poll Home Assistant, in seconds.
POLL_INTERVAL=1.0

# Screen power management (DPMS). When enabled the dashboard wakes the monitor
# while playing and blanks it after SCREEN_SLEEP_GRACE seconds of nothing
# playing. Set to false to leave the screen alone.
SCREEN_SLEEP_ENABLED=true
SCREEN_SLEEP_GRACE=60
