# Copy this file to .env and fill in your values. The .env file is gitignored.

# Home Assistant base URL (no trailing slash).
HA_BASE_URL=http://homeassistant.local:8123

# Long-lived access token: HA profile -> Security -> Long-lived access tokens.
HA_TOKEN=paste-your-long-lived-token-here

# The media_player entity to display. Not sure of the id? Start the service and
# open http://<pi>:8080/debug/players to list every media_player HA knows.
HA_ENTITY_ID=media_player.living_room

# Port Flask listens on. If you change this, update the URL in config/xinitrc too.
DASHBOARD_PORT=8080

# How often to poll Home Assistant, in seconds.
POLL_INTERVAL=1.0

# Screen power management. When enabled the dashboard wakes the display while
# playing and powers it down after SCREEN_SLEEP_GRACE seconds of nothing playing.
SCREEN_SLEEP_ENABLED=true
SCREEN_SLEEP_GRACE=60

# How the screen is powered on/off:
#   xset     - X11 DPMS (default; right for KMS / most desktops).
#   vcgencmd - Raspberry Pi firmware HDMI power. Use this on the legacy
#              framebuffer driver (KMS disabled), where xset only blanks the
#              picture to black but leaves the backlight on.
#   command  - run your own SCREEN_ON_CMD / SCREEN_OFF_CMD (e.g. a smart plug,
#              wlr-randr on Wayland, cec-ctl for an HDMI-CEC TV).
SCREEN_CONTROL=xset
# Only used when SCREEN_CONTROL=command:
SCREEN_ON_CMD=
SCREEN_OFF_CMD=
